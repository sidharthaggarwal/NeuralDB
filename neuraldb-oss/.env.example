# NeuralDB — Environment Configuration
# Copy to .env and fill in your values
# NEVER commit .env to version control

# ── Authentication ────────────────────────────────────────────────────────────
# REQUIRED in production — generate with: openssl rand -hex 32
# Run:  openssl rand -hex 32
# Then paste the output here:
NEURALDB_API_KEY=

# Disable auth for local dev only (never in production)
NEURALDB_AUTH=true

# ── Storage ───────────────────────────────────────────────────────────────────
NEURALDB_DATA_PATH=/data

# ── Vector Index ──────────────────────────────────────────────────────────────
# Must match your embedding model's output dimension:
#   text-embedding-3-small  → 1536
#   all-MiniLM-L6-v2         → 384
#   nomic-embed-text         → 768
NEURALDB_VECTOR_DIM=128

# ── Rate Limiting ─────────────────────────────────────────────────────────────
NEURALDB_RATE_LIMIT=true
NEURALDB_RPM=120
NEURALDB_BURST=20

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8000
LOG_LEVEL=INFO
WORKERS=2
CORS_ORIGINS=*

# NeuralDB .gitignore

# Environment / secrets — NEVER commit
.env
.env.*
!.env.example

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
env/
pip-wheel-metadata/
*.whl

# Test artifacts
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.tox/
.nox/
bandit-report.json

# Database files — don't commit data
data/
*.pkl
*.db

# IDE
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# Docker
docker-compose.override.yml

# Logs
*.log
